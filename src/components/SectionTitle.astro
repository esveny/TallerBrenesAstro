---
export interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = true, light = false } = Astro.props;
---

<div class={`mb-12 ${centered ? 'text-center' : ''}`}>
  <h2 class={`text-3xl md:text-4xl font-bold mb-4 scroll-animate fade-up ${light ? 'text-[#f5f0e8]' : 'text-[#1a1a1a]'}`}>
    {title}
  </h2>
  {subtitle && (
    <p class={`text-lg max-w-3xl mx-auto scroll-animate fade-up ${light ? 'text-[#d1d5db]' : 'text-[#4b5563]'}`}>
      {subtitle}
    </p>
  )}
</div>