---
export interface Props {
  title: string;
  description: string;
  icon: string;
  delay?: number;
}

const { title, description, icon, delay = 0 } = Astro.props;
---

<div 
  class="spotlight-card relative overflow-hidden bg-white p-8 rounded-2xl shadow-lg card-hover scroll-animate fade-up"
  style={`transition-delay: ${delay}s`}
>
  <div class="text-center">
    <div class="text-5xl mb-6 flex justify-center items-center">
      {icon.includes('data:image') || icon.includes('.svg') || icon.includes('.png') || icon.includes('.jpg') || icon.startsWith('http') ? (
        <div class="w-16 h-16 flex items-center justify-center bg-gray-50 rounded-full border-2 border-gray-200 shadow-md">
          <img src={icon} alt="Icon" class="w-18 h-18 rounded-lg" />
        </div>
      ) : (
        <span>{icon}</span>
      )}
    </div>
    <h3 class="text-xl font-bold text-dark-800 mb-4">{title}</h3>
    <p class="text-gray-600 leading-relaxed">{description}</p>
  </div>
  <div class="spotlight-glow pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500"></div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.spotlight-card').forEach(card => {
    const glow = card.querySelector<HTMLElement>('.spotlight-glow');
    if (!glow) return;

    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      glow.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(15, 40, 100, 0.13), transparent 70%)`;
      glow.style.opacity = '1';
    });

    card.addEventListener('mouseleave', () => {
      glow.style.opacity = '0';
    });
  });
</script>