---
import BusinessStatus from './BusinessStatus.astro';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Inicio',    href: '/' },
  { label: 'Servicios', href: '/servicios' },
  { label: 'Galería',   href: '/productos' },
  { label: 'Contacto',  href: '/contacto' },
];
---

<nav id="navbar" class="bg-gradient-to-r from-black/90 via-dark-900/90 to-black/90 backdrop-blur-md sticky top-0 z-50 shadow-lg border-b border-white/5 transition-all duration-300">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between py-4">

      <!-- Logo -->
      <div class="flex items-center">
        <a
          href="/"
          class="block hover:scale-105 transition-transform duration-300 group"
          aria-label="Ir al inicio - Taller Industrial Brenes"
        >
          <img
            src="https://zjpgpagdnpmfgmesglvv.supabase.co/storage/v1/object/public/images/LogoTBrenesLetrasBlancas.png"
            alt="Taller Industrial Brenes Logo"
            class="h-14 w-auto cursor-pointer filter drop-shadow-lg group-hover:drop-shadow-xl transition-all"
          />
        </a>
      </div>

      <!-- Desktop PillNav -->
      <div class="hidden md:flex items-center gap-4">
        <div class="pillnav-bar" role="menubar">
          {navItems.map(item => {
            const isActive = currentPath === item.href;
            return (
              <a
                href={item.href}
                role="menuitem"
                class={`pillnav-item${isActive ? ' is-active' : ''}`}
              >
                <span class="pillnav-bubble" aria-hidden="true"></span>
                <span class="pillnav-label">{item.label}</span>
                <span class="pillnav-label-hover" aria-hidden="true">{item.label}</span>
              </a>
            );
          })}
        </div>
        <div class="pl-4 border-l border-white/10">
          <BusinessStatus id="status-indicator-desktop" />
        </div>
      </div>

      <!-- Mobile hamburger -->
      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          class="text-white hover:text-accent-300 p-2"
          aria-label="Abrir menú"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pb-4 border-t border-white/10 mt-2">
      <div class="flex flex-col space-y-1 pt-2">
        {navItems.map(item => {
          const isActive = currentPath === item.href;
          return (
            <a
              href={item.href}
              class={`text-white px-4 py-3 rounded-lg transition-all duration-300 ${
                isActive ? 'bg-white/10 text-accent-400' : 'hover:bg-white/5 hover:text-accent-300'
              }`}
            >
              {item.label}
            </a>
          );
        })}
        <div class="px-4 py-3 border-t border-white/10 mt-2">
          <BusinessStatus id="status-indicator-mobile" />
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  /* ── PillNav bar ─────────────────────────────────── */
  .pillnav-bar {
    display: flex;
    align-items: center;
    gap: 3px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    padding: 4px;
  }

  /* ── Individual pill ─────────────────────────────── */
  .pillnav-item {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 38px;
    padding: 0 20px;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.85);
    background: transparent;
    transition: color 0.25s ease;
    white-space: nowrap;
    cursor: pointer;
  }

  /* Active pill — white background, dark text */
  .pillnav-item.is-active {
    background: #ffffff;
    color: #0f172a;
  }
  .pillnav-item.is-active .pillnav-bubble {
    display: none;
  }

  /* ── Hover bubble ────────────────────────────────── */
  .pillnav-bubble {
    position: absolute;
    left: 50%;
    bottom: -4px;
    width: 220%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #ffffff;
    transform: translate(-50%, 0) scale(0);
    transform-origin: 50% 100%;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 1;
    pointer-events: none;
  }

  .pillnav-item:not(.is-active):hover .pillnav-bubble {
    transform: translate(-50%, 0) scale(1.6);
  }

  /* ── Text layers ─────────────────────────────────── */
  .pillnav-label {
    position: relative;
    z-index: 2;
    display: inline-block;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                opacity   0.4s ease;
  }

  .pillnav-label-hover {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0f172a;
    font-weight: 600;
    font-size: 0.875rem;
    z-index: 3;
    pointer-events: none;
    transform: translateY(110%);
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                opacity   0.4s ease;
  }

  .pillnav-item:not(.is-active):hover .pillnav-label {
    transform: translateY(-110%);
    opacity: 0;
  }

  .pillnav-item:not(.is-active):hover .pillnav-label-hover {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── Active label color fix ──────────────────────── */
  .pillnav-item.is-active .pillnav-label {
    color: #0f172a;
  }

  /* ── Navbar scroll effect ────────────────────────── */
  #navbar.scrolled {
    @apply shadow-2xl bg-gradient-to-r from-black via-dark-900 to-black border-b border-white/10;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const button = document.getElementById('mobile-menu-button');
    const menu   = document.getElementById('mobile-menu');
    const navbar = document.getElementById('navbar');

    button?.addEventListener('click', () => menu?.classList.toggle('hidden'));

    menu?.querySelectorAll('a').forEach(link =>
      link.addEventListener('click', () => menu?.classList.add('hidden'))
    );

    window.addEventListener('scroll', () => {
      navbar?.classList.toggle('scrolled', window.pageYOffset > 50);
    });
  });
</script>
